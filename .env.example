# DeltaForge -- Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ── Angel One SmartAPI Credentials ────────────────────────────
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_PASSWORD=your_password_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# ── Alerts ────────────────────────────────────────────────────
# Set ALERT_METHOD to "slack" (recommended), "imessage", or "telegram"
ALERT_METHOD=slack

# Slack (recommended -- create app at https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_CHANNEL_ID=C0XXXXXXXXX

# iMessage (macOS only)
IMESSAGE_RECIPIENT=+91XXXXXXXXXX

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Trading Configuration ────────────────────────────────────
TRADING_MODE=paper
STARTING_CAPITAL=10000
CAPITAL_DEPLOY_PCT=60

# ── Risk Limits ──────────────────────────────────────────────
DAILY_LOSS_LIMIT_PCT=25
DAILY_PROFIT_TARGET_PCT=35
WEEKLY_LOSS_LIMIT_PCT=50
MAX_CONSECUTIVE_LOSSES=5
MAX_VIX_THRESHOLD=18

# ── Premium / Options Model ─────────────────────────────────
PREMIUM_SL_PCT=15
PREMIUM_TARGET_PCT=20

# ── Strategy / Engine ────────────────────────────────────────
CONFLUENCE_THRESHOLD=55
MIN_STRENGTH=STRONG
PULLBACK_MAX_SIGNALS_PER_DAY=5
MAX_SIMULTANEOUS_POSITIONS=2
TRAIL_TRIGGER_PCT=12
TRAIL_PCT=8
SCAN_WARMUP_BARS=50
SHOCK_THRESHOLD_PCT=1.5
SHOCK_LOOKBACK_BARS=3

# ── Timing (IST) ────────────────────────────────────────────
ENTRY_END=14:30

# ── Dashboard ────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8900
# DASHBOARD_CORS_ORIGINS=http://localhost:8900,http://127.0.0.1:8900
# DASHBOARD_API_TOKEN=your_secret_token_here
